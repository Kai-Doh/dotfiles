# Copy this file to credentials.toml and fill in your values.
# credentials.toml is gitignored — it will never be committed.

[server]
url          = "https://your-navidrome-server.example.com"
auth_method  = "plaintext"
username     = "your_username"

# Required if auth_method = "plaintext"
password = "your_password"

# Required if auth_method = "hashed"
password_token = ""
password_salt  = ""

# Required if auth_method = "api_key"
api_key = ""

[security]
redact_credentials_in_logs = true

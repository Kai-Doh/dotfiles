{
    "layer": "top",
    "position": "top",
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/music", "pulseaudio", "backlight", "battery", "custom/updates", "tray", "custom/lock", "custom/power"],
    "hyprland/workspaces": {
         "disable-scroll": true,
         "sort-by-name": true,
         "format": " {name} ",
         "format-icons": {
             "default": "",
         },
     },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "custom/music": {
        "format": "蟀潥 {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ "{{" }} title {{ "}}" }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },
    "clock": {
        "timezone": "{{ .timezone }}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "蟀儹 {:%d/%m/%Y}",
        "format": "蟀儹 {:%a %d  %H:%M}"
    },
    "backlight": {
        "device": "{{ .backlight }}",
        "format": "{icon}",
        "format-icons": ["蟀優", "蟀優", "蟀優", "蟀儫", "蟀儫", "蟀儫", "蟀儬", "蟀儬", "蟀儬"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "蟀倓",
        "format-plugged": "蟀殽",
        "format-alt": "{icon}",
        "format-icons": ["蟀値", "蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖", "蟀伖"]
    },
"pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "蟀潫",
        "format-icons": {
            "default": ["蟀暱", "蟀杸", "蟀暰"]
        },
        "on-click": "pavucontrol"
    },
    "custom/updates": {
        "exec": "~/.config/waybar/update-count.sh",
        "interval": 3600,
        "signal": 8,
        "format": "蟀毎 {}",
        "tooltip": false,
        "on-click": "kitty -e bash -c 'yay -Syu; pkill -RTMIN+8 waybar'"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "蟀尵",
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "wlogout &",
        "format": "蟀惀"
    }
}
